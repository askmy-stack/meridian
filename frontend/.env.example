# Frontend environment example.
# Copy to .env.local for development overrides (gitignored).

# --- Local development ---
# Option A (recommended): Vite proxy — API on :8002, frontend calls /api/*
VITE_API_BASE_URL=/api

# Option B: Direct API URL (no proxy) — e.g. production or standalone API
# VITE_API_URL=http://localhost:8002
# VITE_API_BASE_URL=http://localhost:8002

# --- Production (Vercel) ---
# Set VITE_API_BASE_URL to your Railway API URL, e.g.:
# VITE_API_BASE_URL=https://meridian-api-production.up.railway.app

# Optional: Mapbox token for premium Mapbox tiles. If unset, Carto dark tiles load via MapLibre (no key required).
VITE_MAPBOX_TOKEN=
