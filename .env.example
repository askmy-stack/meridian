# Core
ENVIRONMENT=local
LOG_LEVEL=INFO

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meridian
POSTGRES_USER=meridian
POSTGRES_PASSWORD=change-me

# TimescaleDB
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_DB=meridian_timeseries
TIMESCALE_USER=meridian
TIMESCALE_PASSWORD=change-me

# Qdrant
QDRANT_URL=http://localhost:6333

# Optional data source credentials
ACLED_API_KEY=
ACLED_EMAIL=
AISHUB_API_KEY=
NASA_FIRMS_MAP_KEY=

# API security (REQUIRED before launching API in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap users for /auth/login (development only)
MERIDIAN_ADMIN_USERNAME=admin
MERIDIAN_ADMIN_PASSWORD=change-me-strong-password
MERIDIAN_VIEWER_USERNAME=viewer
MERIDIAN_VIEWER_PASSWORD=change-me-strong-password

# CORS allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Slack alerting (optional)
SLACK_WEBHOOK_URL=

# MLflow (Phase 3)
MLFLOW_TRACKING_URI=http://localhost:5000
