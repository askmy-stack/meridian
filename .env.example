# Core (use development | production | test)
ENVIRONMENT=development
LOG_LEVEL=INFO

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Neo4j
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=meridian_password

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meridian
POSTGRES_USER=meridian
POSTGRES_PASSWORD=change-me

# TimescaleDB (optional — score/event history; graceful skip when down)
TIMESCALE_URL=postgresql://meridian:change-me@localhost:5433/meridian_timeseries
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_DB=meridian_timeseries
TIMESCALE_USER=meridian
TIMESCALE_PASSWORD=change-me

# Qdrant
QDRANT_URL=http://localhost:6333

# RAG / Copilot (Phase B)
RAG_EMBED_MODE=hash
RAG_EMBED_MODEL=all-MiniLM-L6-v2
LLM_PROVIDER=stub
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ENABLE_LLM_CLASSIFIER=false

# Optional data source credentials
ACLED_API_KEY=
ACLED_EMAIL=
AISHUB_USERNAME=
AISHUB_PASSWORD=
NASA_FIRMS_MAP_KEY=

# Require JWT for supplier writes (auto-enabled when ENVIRONMENT=production)
MERIDIAN_REQUIRE_AUTH=false

# API security (REQUIRED before launching API in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap users for /auth/login (development only)
MERIDIAN_ADMIN_USERNAME=admin
MERIDIAN_ADMIN_PASSWORD=change-me-strong-password
MERIDIAN_VIEWER_USERNAME=viewer
MERIDIAN_VIEWER_PASSWORD=change-me-strong-password

# CORS allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Slack alerting (optional)
SLACK_WEBHOOK_URL=

# MLflow (Phase 3)
MLFLOW_TRACKING_URI=http://localhost:5000
